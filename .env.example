# ======================
# ToknNews Environment Template
# ======================

# === API KEYS ===
GROK_API_KEY=your_grok_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
MARKETAUX_API_KEY=your_marketaux_key_here
XAI_BEARER_TOKEN=your_x_bearer_token_here

# === Database ===
DATABASE_URL=sqlite:///data/ingestion/ingestion.db

# === External URLs ===
MAIN_URL=http://your_server_ip:4007
FRONTEND_URL=http://your_server_ip:4007

# === Social / Posting ===
X_API_KEY=
X_API_SECRET=

# === Feature Flags ===
ENABLE_GROK_CONTEXT=true
DISABLE_MCP=true

# === Paths ===
UPLOAD_DIRECTORY=/opt/toknnews/uploads
