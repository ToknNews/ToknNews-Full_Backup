#!/usr/bin/env python3
"""
enrich.py
TOKEN NEWS — Story Enrichment Engine

Responsibilities:
 - Normalize raw feed items (RSS + APIs)
 - Hybrid domain classification (keyword → GPT fallback)
 - Sentiment scoring
 - Volatility & social heat detection
 - Importance scoring
 - Anchor suggestions (domain → personas)
 - Final output schema compatible with timeline builder + PD engine
"""

import re
import time
from openai import OpenAI
import os

client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))

# Import domain anchors from PD module
from script_engine.director.pd_controller import get_domain_anchors


# ============================================================
# 1. NORMALIZATION
# ============================================================

def normalize_item(raw):
    """Convert raw API/RSS item into basic structured form."""

    return {
        "headline": raw.get("title") or raw.get("headline"),
        "summary": raw.get("summary") or raw.get("description") or "",
        "source": raw.get("source", "unknown"),
        "url": raw.get("url", None),
        "timestamp": raw.get("published_at", time.time()),
        "raw": raw,
    }


# ============================================================
# 2. KEYWORD-BASED DOMAIN CLASSIFIER
# ============================================================

DOMAIN_KEYWORDS = {
    "macro":      ["inflation", "cpi", "rates", "fed", "treasury", "macro"],
    "markets":    ["bitcoin", "btc", "eth", "market", "stock", "equity", "price", "chart"],
    "regulation": ["sec", "lawsuit", "regulator", "court", "congress", "ban"],
    "defi":       ["defi", "liquidity pool", "dex", "amm", "yield", "staking"],
    "onchain":    ["hacked", "exploit", "bridge", "validator", "on-chain", "smart contract"],
    "ai":         ["ai", "llm", "compute", "gpu"],
    "venture":    ["funding", "raised", "seed", "series", "venture", "vc"],
    "retail":     ["shoppers", "consumer", "wallets", "adoption", "mainstream"],
    "sentiment":  ["community", "viral", "trend", "fomo", "panic", "memecoin"],
    "meta":       ["crypto twitter", "meme", "social"],
}

def keyword_domain(headline, summary):
    text = (headline + " " + summary).lower()
    for domain, words in DOMAIN_KEYWORDS.items():
        if any(w in text for w in words):
            return domain
    return None


# ============================================================
# 3. GPT FALLBACK DOMAIN CLASSIFIER
# ============================================================

def gpt_classify_domain(headline, summary):
    prompt = f"""
Classify the following crypto headline into EXACTLY ONE domain:

Domains:
- macro
- markets
- regulation
- defi
- onchain
- ai
- venture
- retail
- sentiment
- meta
- general

Headline: {headline}
Summary: {summary}

Respond with ONLY the domain word.
    """
    try:
        resp = client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=4,
            temperature=0
        )
        return resp.choices[0].message.content.strip().lower()
    except:
        return "general"


# ============================================================
# 4. SENTIMENT ANALYSIS (lightweight)
# ============================================================

POSITIVE_WORDS = ["surge", "gain", "record", "rise", "upgrade", "partner", "launch"]
NEGATIVE_WORDS = ["crash", "fear", "lawsuit", "ban", "exploit", "hack", "down", "collapse"]

def score_sentiment(headline, summary):
    text = (headline + " " + summary).lower()
    score = 0

    for w in POSITIVE_WORDS:
        if w in text:
            score += 1

    for w in NEGATIVE_WORDS:
        if w in text:
            score -= 1

    if score > 0:
        return "positive"
    if score < 0:
        return "negative"
    return "neutral"


# ============================================================
# 5. VOLATILITY HEAT DETECTOR (aligns w/ PD)
# ============================================================

VOL_WORDS = ["spike", "surge", "crash", "collapse", "flash", "liquidation", "panic"]

def score_volatility(headline, summary):
    text = (headline + " " + summary).lower()
    return sum(1 for w in VOL_WORDS if w in text)


# ============================================================
# 6. IMPORTANCE SCORING
# ============================================================

def compute_importance(sentiment, volatility, domain):
    score = 5

    if volatility > 2:
        score += 2

    if domain in ["macro", "markets", "regulation", "defi"]:
        score += 1

    if sentiment == "negative":
        score += 1

    return min(score, 10)


# ============================================================
# 7. ANCHOR SUGGESTION (domain → personas)
# ============================================================

def suggest_anchors(domain):
    anchors = get_domain_anchors(domain)
    return anchors[:2]  # up to 2 for duo option


# ============================================================
# 8. MASTER ENRICHMENT FUNCTION
# ============================================================

def enrich(raw_item):
    """
    Input: raw API/RSS item
    Output: enriched story object
    """

    item = normalize_item(raw_item)
    headline = item["headline"] or ""
    summary  = item["summary"] or ""

    # ---- hybrid domain classifier ----
    domain = keyword_domain(headline, summary)
    if not domain:
        domain = gpt_classify_domain(headline, summary)

    # ---- sentiment + volatility ----
    sentiment  = score_sentiment(headline, summary)
    volatility = score_volatility(headline, summary)

    # ---- importance + anchors ----
    importance = compute_importance(sentiment, volatility, domain)
    anchors    = suggest_anchors(domain)

    item.update({
        "domain": domain,
        "sentiment": sentiment,
        "volatility": volatility,
        "importance": importance,
        "anchors": anchors
    })

    return item
